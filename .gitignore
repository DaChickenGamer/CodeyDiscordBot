# Node modules managed by pnpm
node_modules/
.pnpm/
.pnpm-debug.log

# TypeScript build output
dist/
build/
lib/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (keep secrets out of version control)
.env
.env.*.local

# OS-specific files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# TypeScript cache
*.tsbuildinfo

# Test coverage
coverage/

# PM2 process manager
.pids/

# Debug output
*.tgz

# Yarn/NPM lock files (not used with pnpm)
package-lock.json
yarn.lock

# Include pnpm lock file (uncomment if you WANT to ignore it — usually you should keep it in version control)
# pnpm-lock.yaml